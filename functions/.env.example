# Copy to .env for LOCAL emulator testing ONLY. NEVER commit a real key (SPEC §7.7).
# In production these are Cloud Functions secrets (firebase functions:secrets:set ANTHROPIC_API_KEY),
# never bundled in the iOS app — the app calls your callable functions; the functions call Claude.

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Tier 2 clinical layer (SPEC §2.7, §14). MUST stay "false" until every §14 prerequisite exists.
# When false, requestClinicalReview is hard-disabled and no AI clinical output can reach a patient.
CLINICAL_TIER_ENABLED=false

# The provenance audit is enforced by DEFAULT in every environment: a safety table claiming
# verified=true is treated as unverified (fail-safe) unless every entry has reviewedBy +
# reviewedAt. To intentionally load synthetic verified-but-unprovenanced tables in the emulator
# for testing, set APP_ENV=test (or ALLOW_UNPROVENANCED_CONFIG=true). Leave unset in production.
APP_ENV=development
