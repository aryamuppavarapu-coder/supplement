# Copy to .env.local. These are Firebase WEB config values (not secrets — they identify
# the project, access is controlled by Auth + the `clinician` custom claim + security rules).
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_APP_ID=
VITE_FB_FUNCTIONS_REGION=us-central1
