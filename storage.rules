rules_version = '2';

// SPEC §4: files live at users/{uid}/reports/{reportId}/<file>; access via signed URLs
// from Cloud Functions only. The client may upload its own report but cannot read raw
// files back directly.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/reports/{reportId}/{fileName=**} {
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 32 * 1024 * 1024            // SPEC §5.1 request size limit
        && request.resource.contentType.matches('application/pdf|image/jpeg|image/png');
      allow read: if false;                                     // functions issue signed URLs
      allow delete: if request.auth != null && request.auth.uid == uid;  // SPEC §9
    }
  }
}
