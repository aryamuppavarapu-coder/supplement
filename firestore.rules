rules_version = '2';

// SPEC §2.2, §2.6, §4, §9. The client can read its own data and write its own profile,
// but it can NEVER write the fields that decide patient-facing status — markers, plans,
// and clinical reviews are written only by Cloud Functions (Admin SDK bypasses rules).
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      // Profile, medications, conditions, consent, disclosure flags — owner-writable, EXCEPT
      // server-authoritative fields. `subscription` is mirrored from the RevenueCat webhook
      // (Admin SDK), so the client must never write it.
      allow create: if isOwner(uid) && !('subscription' in request.resource.data);
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription']);
      allow delete: if false;                    // account deletion runs server-side (deleteAccount fn, §9)

      match /reports/{reportId} {
        allow read: if isOwner(uid);
        // Created by the storage trigger and deleted by the deleteReport fn (Admin SDK), so the
        // markers subcollection + Storage file are purged too (§2.2, §9).
        allow create, update, delete: if false;

        match /markers/{markerId} {
          allow read: if isOwner(uid);
          allow write: if false;                 // computedStatus is function-authored (§2.2)
        }
      }

      match /plans/{planId} {
        allow read: if isOwner(uid);
        allow write: if false;                   // gated plan is function-authored (§2.4)
      }
    }

    // Tier-2 PHI (SPEC §4, §14). Never client-accessible — clinician console uses Admin SDK.
    match /clinicalReviews/{reviewId} {
      allow read, write: if false;
    }

    // Doctor directory (SPEC §3.6, §10.3). Public read to signed-in users; no client writes.
    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
